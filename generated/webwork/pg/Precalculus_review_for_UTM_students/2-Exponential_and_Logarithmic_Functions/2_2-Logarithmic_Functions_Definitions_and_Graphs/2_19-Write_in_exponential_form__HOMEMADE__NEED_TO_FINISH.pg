Context("Numeric");
$f = Formula("sqrt(x)");
$derivative = Formula("1/(2sqrt(x))");
Context("LimitedRadical");
$a = Formula("2sqrt(3)");
Context("LimitedNumeric");
$b = Real(sqrt(12));
Context("Interval");
$domain = Interval("[0,inf)");
Context("Point");
$point = Point("(4,2)");
Context("RestrictedDomains");
$restricted = Formula("x, x >= 0");

############################################################
# Body
############################################################

BEGIN_PGML
Write each of the following in exponential form.
a.  [`\log_2(0.25)=-2`]

a.  [`\log_{27}(1)=0`]

a.  [`\log(1000)=3`]

a.  [`\log_4256=4`]

END_PGML

