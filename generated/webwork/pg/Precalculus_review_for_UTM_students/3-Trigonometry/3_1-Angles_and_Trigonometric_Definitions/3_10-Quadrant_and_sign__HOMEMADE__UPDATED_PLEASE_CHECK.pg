Context("Numeric");
$popup1quadrant = PopUp(['?','in Quadrant I','in Quadrant II','in Quadrant III','in Quadrant IV','not in any quadrant'],1);
$popup1sign = PopUp(['?','positive','negative','0','undefined'],1);
        $popup2quadrant = PopUp(['?','in Quadrant I','in Quadrant II','in Quadrant III','in Quadrant IV', 'not in any quadrant'],2);
$popup2sign = PopUp(['?','positive','negative','0','undefined'],2);
        $popup3quadrant = PopUp(['?','in Quadrant I','in Quadrant II','in Quadrant III','in Quadrant IV','not in any quadrant'],4);
$popup3sign = PopUp(['?','positive','negative','0','undefined'],2);
        $popup4quadrant = PopUp(['?','in Quadrant I','in Quadrant II','in Quadrant III','in Quadrant IV','not in any quadrant'],5);
$popup4sign = PopUp(['?','positive','negative','0','undefined'],3);
        $popup5quadrant = PopUp(['?','in Quadrant I','in Quadrant II','in Quadrant III','in Quadrant IV','not in any quadrant'],3);
$popup5sign = PopUp(['?','positive','negative','0','undefined'],1);

############################################################
# Body
############################################################

BEGIN_PGML
a.  The angle [`\frac{\pi}{6}`] is [_]{$popup1quadrant}{5}

    and [`\cos \left(\frac{\pi}{6}\right)`] is [_]{$popup1sign}{5}.

a.  The angle [`\frac{2\pi}{3}`] is [_]{$popup2quadrant}{5}

    and [`\tan \left(\frac{2\pi}{3}\right)`] is [_]{$popup2sign}{5}.

a.  The angle [`-\frac{\pi}{4}`] is [_]{$popup3quadrant}{5}

    and [`\sin \left(-\frac{\pi}{4}\right)`] is [_]{$popup3sign}{5}.

a.  The angle [`\frac{3\pi}{2}`] is [_]{$popup4quadrant}{5}

    and [`\cos \left(\frac{3\pi}{2}\right)`] is [_]{$popup4sign}{5}.

a.  The angle [`\frac{7\pi}{6}`] is [_]{$popup5quadrant}{5}

    and [`\cot \left(\frac{7\pi}{6}\right)`] is [_]{$popup5sign}{5}.

END_PGML

