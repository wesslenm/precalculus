Context("LimitedNumeric");
$a = Compute(random(-9, 12, 1));
$b = $a/2;
$ans = cos(pi*$a/2);

############################################################
# Body
############################################################

BEGIN_PGML
Evaluate [`\cos \left([$b]\pi\right)`] without using a calculator.

[`\cos \left([$b]\pi\right) =`]  [_]{$ans}{6}.

END_PGML

