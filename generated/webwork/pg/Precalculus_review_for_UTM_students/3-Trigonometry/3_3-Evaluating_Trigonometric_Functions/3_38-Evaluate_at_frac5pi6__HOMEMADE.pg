TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context("Fraction");

$ans1 = Compute("-1/2")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );
$ans2 = Compute("-sqrt(3)/2")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );
$ans3 = Compute("sqrt(3)")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );
$ans4 = Compute("-2")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );               

   Context()->functions->disable('All');
   Context()->functions->enable('sqrt');

############################################################
# Body
############################################################

BEGIN_PGML
Evaluate the following. Answer in exact form (using square roots if needed).

(a) [` \sin \left(-\frac{5\pi}{6}\right) =`]  [_]{$ans1}{10}.

(b) [` \cos \left(-\frac{5\pi}{6}\right) =`]  [_]{$ans2}{10}.

(c) [` \cot \left(-\frac{5\pi}{6}\right) =`]  [_]{$ans3}{10}.

(d) [` \csc \left(-\frac{5\pi}{6}\right) =`]  [_]{$ans4}{10}.

END_PGML

