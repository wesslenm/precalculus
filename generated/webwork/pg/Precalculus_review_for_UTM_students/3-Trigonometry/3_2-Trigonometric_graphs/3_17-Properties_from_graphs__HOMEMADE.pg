loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context("Numeric");

$a = random(2,9,1);
$ans1 = Compute("1")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );
$ans2 = Compute("0")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );
$ans3 = Compute("-pi/2")->with(
         tolType => 'absolute',
         tolerance => .000000000000000000001,   );

############################################################
# Body
############################################################

BEGIN_PGML
Use the graphs of trigonometric functions to find the following information.

(a) [`\cos 0 = `] [_]{$ans1}{6}

(b) [`\tan \pi = `] [_]{$ans2}{6}

(c) All values of [`x`] in the interval [`[-2\pi, 2\pi]`] where [`\sin x = -1\text{.}`] [_]{$ans3}{6}

END_PGML

############################################################
# End Problem
############################################################

ENDDOCUMENT();
