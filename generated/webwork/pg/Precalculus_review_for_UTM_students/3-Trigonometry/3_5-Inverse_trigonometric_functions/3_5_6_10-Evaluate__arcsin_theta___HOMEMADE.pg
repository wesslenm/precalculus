  Context("Numeric");
  $a = Compute(random(2, 12, 1));
  $b = Compute($a-1);
  $ans = Compute("pi/4")->with(
           tolType => 'absolute',
           tolerance => .000000000000000000001,   );

Context()->functions->disable('trig');

