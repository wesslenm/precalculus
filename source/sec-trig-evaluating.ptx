      $b = $a/2;
      $ans = cos(pi*$a/2);
    </pg-code>

    <statement>
      <p>Evaluate <m>\cos \left(<var name="$b"/>\pi\right)</m> without using a calculator.</p>
      <p><m>\cos \left(<var name="$b"/>\pi\right) =</m>  <var name="$ans" width="6"/>.</p>
    </statement>

  </webwork>
</exercise>

