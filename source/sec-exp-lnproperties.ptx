<exercise><title>(Challenge) Arrange by size</title>
    <introduction>
      <p>
        (Not rendomizable)
      </p>
    </introduction>
    <webwork>
      <pg-code>
        Context("Numeric");
        $popup1 = PopUp(['?','power','exponential','linear','quadratic'],1);
        $popup2 = PopUp(['?','power','exponential','linear','quadratic'],1);
        $popup3 = PopUp(['?','power','exponential','linear','quadratic'],1);
        $popup4 = PopUp(['?','power','exponential','linear','quadratic'],1);
        $popup5 = PopUp(['?','power','exponential','linear','quadratic'],1);
      </pg-code>
      <statement>
        <p>
          Suppose <m>A</m> and <m>B</m> are positive constants such that <m>0 \lt A \lt AB \lt 1 \lt B</m>. Arrange the following quantities from smallest to largest. 
          <ol>
            <li>
              <p>
                <m>0</m>
              </p>
            </li>
            <li>
              <p>
                <m>\ln A</m>
              </p>
            </li>
            <li>
              <p>
                <m>\ln B</m>
              </p>
            </li>
            <li>
              <p>
                <m>\ln A + \ln B</m>
              </p>
            </li>
            <li>
              <p>
                <m>\ln (B^A)</m>
              </p>
            </li>
          </ol>
        </p>
        <p>
         <var name="$popup1" form="popup"/>  <m>\lt</m> <var name="$popup2" form="popup"/>  <m>\lt</m> <var name="$popup3" form="popup"/>  <m>\lt</m> <var name="$popup4" form="popup"/>  <m>\lt</m> <var name="$popup5" form="popup"/>
        </p>
      </statement>
    </webwork>
  </exercise>





