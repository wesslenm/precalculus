<exercise><title>True or False? - HOMEMADE</title>
  <introduction>
    <p>
      (Not randomizable)
    </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      $a = random(3,6,1);
      $ans = Compute("$a*x^($a-1)");
$popup1 = PopUp(['?','True','False'],2);
$popup2 = PopUp(['?','True','False'],2);
$popup3 = PopUp(['?','True','False'],1);
$popup4 = PopUp(['?','True','False'],1);
$popup5 = PopUp(['?','True','False'],2);
$popup6 = PopUp(['?','True','False'],1);

      Context()->functions->disable('All');
      Context()->functions->enable('sqrt');
    </pg-code>

    <statement>
       <p>
      Suppose <m>a, b, c, x,</m> and <m>y</m> are positive numbers.  
        Which of the following statements are true, and which are false? 
      </p>
      <p>
      Note: For a statement involving <m>a, b,c,x,</m> and/or <m>y</m> to be true, it must be true for ALL positive numbers <m>a, b,c,x,</m> and <m>y</m>. 
      </p>
<p>
  <ol>
    <li>
      <p>
        <m>\ln (x^2) = (\ln x)^2</m> <var name="$popup1" form="popup"/>
      </p>
    </li>
    <li>
      <p>
        <m>\ln a + \ln b + \ln c=\ln (a+b+c)</m> <var name="$popup2" form="popup"/>
      </p>
    </li>
        <li>
      <p> 
        <m>\ln x^{-1}=-\ln x </m> <var name="$popup3" form="popup"/> 
      </p>
    </li>
        <li>
      <p>
        <m>\ln \sqrt{4x}=\ln 2 + \frac{1}{2}\ln x</m> <var name="$popup4" form="popup"/> 
      </p>
    </li>
    <li>
      <p>
        <m>\ln \left(\frac{1}{x}\right)=\frac{1}{\ln x}</m> <var name="$popup5" form="popup"/> 
      </p>
    </li>
    <li>
      <p>
        <m>\ln 7x^2 y^5=\ln 7 + 2 \ln x + 5 \ln y</m> <var name="$popup6" form="popup"/> 
      </p>
    </li>
  </ol>
</p>
    </statement>
  </webwork>
</exercise>

<exercise><title>True or False? - HOMEMADE</title>
  <introduction>
    <p>
      (Not randomizable)
    </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      $a = random(3,6,1);
      $ans = Compute("$a*x^($a-1)");
$popup1 = PopUp(['?','True','False'],1);
$popup2 = PopUp(['?','True','False'],2);
$popup3 = PopUp(['?','True','False'],1);
$popup4 = PopUp(['?','True','False'],1);
$popup5 = PopUp(['?','True','False'],2);
$popup6 = PopUp(['?','True','False'],1);

      Context()->functions->disable('All');
      Context()->functions->enable('sqrt');
    </pg-code>

    <statement>
       <p>
      Suppose <m>a, b, c,</m> and <m>x</m> are positive numbers.  
        Which of the following statements are true, and which are false? 
      </p>
<p>
  <ol>
    <li>
      <p>
        <m>\ln (e^{6x}) = 6x</m> <var name="$popup1" form="popup"/>
      </p>
    </li>
    <li>
      <p>
        <m>\ln (e^{7x}-e^{4x}) = 3x</m> <var name="$popup2" form="popup"/>
      </p>
    </li>
        <li>
      <p> If <m>\ln x =\ln 75</m> then <m>x=75</m> <var name="$popup3" form="popup"/> 
      </p>
    </li>
        <li>
      <p>
        If <m>x=y</m> then <m>\ln x =\ln y</m> <var name="$popup4" form="popup"/> 
      </p>
    </li>
    <li>
      <p>
        <m>\ln(-e^{x})= -\ln(e^{x})</m> <var name="$popup5" form="popup"/> 
      </p>
    </li>
    <li>
      <p>
        <m>\ln(4e^{x})= \ln 4 + x</m> <var name="$popup6" form="popup"/> 
      </p>
      <p>
        Note: <m>\ln 4 + x = (\ln 4) + x</m>. If we wanted two terms inside the logarithm function, we would need to write <m>\ln (4 + x)</m>.
      </p>
    </li>
  </ol>
</p>
    </statement>
  </webwork>
</exercise>

