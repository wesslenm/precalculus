                <p>
                  This is equivalent to <m>A = B^{C}</m> 
                where <m>A=</m> <var name="$ans4a" width="10"/> and <m>B=</m> <var name="$ans4b" width="10"/> and <m>C=</m> <var name="$ans4c" width="10"/>.
              </p>
            </li>
          </ol> -->
        </p>
      </statement>
    </webwork>
  </exercise> 

