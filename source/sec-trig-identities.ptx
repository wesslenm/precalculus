<exercise><title>Evaluate - HOMEMADE - NOT COMPLETE</title>
  <introduction>
    <p>
        (Not randomizable) 
     </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      <!-- $a = random(2,9,1);
      $b = random(2,9,1); -->
      $ans1 = Compute("-1/(sqrt(3))");
      $ans2 = Compute("1");
      $ans3 = Compute("8");

      Context()->functions->disable('All');
      Context()->functions->enable('sqrt');
    </pg-code>

    <statement>
       <p>
      Suppose that for some angle <m>\theta</m> we know that <m>\sin \theta = -\frac{\sqrt{11}}{6}</m> and 
      <m>\cos \theta = -\frac{5}{6}</m>. 
      Answer the following questions.
    <ol label="a">
      <li>
        <p>
         Evaluate <m>\tan^2 \theta</m> = <var name="$ans1" width="6"/>.
        </p>
      </li>
      <li>
        <p>
          Evaluate <m>\cos^2 \theta + \sin^2 \theta</m> = <var name="$ans2" width="6"/>. 
        </p>
      </li>
      <li>
        <p>
          Evaluate <m>\sec \theta</m> = <var name="$ans3" width="6"/>.
        </p>
      </li>
            <li>
        <p>
          The terminal side of angle <m>\theta</m> is in quadrant xxxxxxxxxxxxxxx <var name="$ans3" width="6"/>.
        </p>
      </li>
    </ol>
      </p>
    </statement>
  </webwork>
</exercise>






<exercise><title>CHECKPOINT - NOT COMPLETE</title>
  <introduction>
    <p>
      (Not randomizable)
    </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      $a = random(3,6,1);
      $ans = Compute("$a*x^($a-1)");
$popup1 = PopUp(['?','True','False'],2);
$popup2 = PopUp(['?','True','False'],1);
$popup3 = PopUp(['?','True','False'],2);
$popup4 = PopUp(['?','True','False'],2);
$popup5 = PopUp(['?','True','False'],1);

      Context()->functions->disable('All');
      Context()->functions->enable('sqrt');
    </pg-code>

    <statement>
      <p>
        Which of the following statements are true, and which are false? 
      </p>
<p>
  <ol>
    <li>
      <p>
        <m>\cos\left( \frac{\pi}{2}\right) + \cos\left(\frac{\pi}{2}\right) = \cos\left(\pi\right)</m>. This is FALSE <var name="$popup1" form="popup"/>
      </p>
    </li>
        <li>
      <p>
        <m>\sin x \csc x = 1</m> TRUE
      </p>
    </li>
    <li>
      <p>
        <m>\frac{1}{\sin x + \cos x} = \csc x + \sec x</m> FALSE
      </p>
    </li>
        <li>
      <p>
        <m>(\sin x)^2 = \sin (x^2)</m> FALSE
      </p>
    </li>
        <li>
      <p>
        <m>\sin x + \sin x = \sin (2x) </m> FALSE
      </p>
    </li>

  </ol>
</p>


      <p><m>\csc \theta \tan \theta - 2\sec \theta =</m>  <var name="$ans" width="6"/>.</p>
    </statement>

  </webwork>
</exercise>

<exercise><title>CHECKPOINT</title>
  <introduction>
    <p>
     p. 691 ex 53-60. 
    </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      $a = random(3,6,1);
      $ans = Compute("$a*x^($a-1)");

      Context()->functions->disable('All');
      Context()->functions->enable('sqrt');
    </pg-code>

    <statement>
      <p>Write the expression <m> <var name="$a"/> \csc \theta \tan \theta - 2\sec \theta </m> in terms of only sine and cosine, and simplify as much as possible. </p>
      <p><m>\csc \theta \tan \theta - 2\sec \theta =</m>  <var name="$ans" width="6"/>.</p>
    </statement>

  </webwork>
</exercise>

<exercise><title>Simplify - HOMEMADE</title>
  <introduction>
    <p>
    (Not randomizable)
    </p>
  </introduction>
  <webwork>
    <pg-code>
      Context("Numeric");
      $a = random(3,6,1);
      $ans = Compute("-(cot x)^2");

      <!-- Context()->functions->disable('All'); -->
      Context()->functions->enable('trig');
    </pg-code>

    <statement>
      <p>
        Simplify the below expression as much as possible.
       </p>
      <p><m>\frac{\cos^2 x}{\cos^2 x-1} \cdot  \frac{1-\csc^2 x}{\tan^2 x - \sec^2 x} =</m>  <var name="$ans" width="6"/>.</p>
    </statement>
  </webwork>
</exercise>

